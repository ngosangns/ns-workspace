{
  "name": "ns-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build:portal": "vite build --config vite.portal.config.ts",
    "check:portal": "vue-tsc -p tsconfig.portal.json --noEmit",
    "lint:doc": "npm run lint:doc:markdown && npm run lint:doc:html && npm run format:doc",
    "lint:doc:fix": "npm run lint:doc:markdown:fix && npm run lint:doc:html && npm run format:doc:fix",
    "lint:doc:markdown": "markdownlint-cli2 \"README.md\" \"docs/**/*.md\" \"presets/**/*.md\"",
    "lint:doc:markdown:fix": "markdownlint-cli2 --fix \"README.md\" \"docs/**/*.md\" \"presets/**/*.md\"",
    "lint:preview": "npm run lint:preview:markdown && npm run lint:doc:html && npm run format:preview",
    "lint:preview:fix": "npm run lint:preview:markdown:fix && npm run lint:doc:html && npm run format:preview:fix",
    "lint:preview:markdown": "markdownlint-cli2 \"docs/**/*.md\"",
    "lint:preview:markdown:fix": "markdownlint-cli2 --fix \"docs/**/*.md\"",
    "lint:portal": "npm run lint:portal:eslint && npm run lint:portal:biome && npm run format:portal",
    "lint:portal:fix": "npm run lint:portal:eslint:fix && npm run lint:portal:biome:fix && npm run format:portal:fix",
    "lint:portal:biome": "biome check --config-path=biome.json",
    "lint:portal:biome:fix": "biome check --write --config-path=biome.json",
    "lint:portal:eslint": "eslint \"internal/portal/portal_ui_src/**/*.{ts,vue}\"",
    "lint:portal:eslint:fix": "eslint \"internal/portal/portal_ui_src/**/*.{ts,vue}\" --fix",
    "lint:doc:html": "node scripts/lint-docs-html.cjs",
    "format:doc": "prettier --ignore-unknown --check README.md \"docs/**/*.{md,html}\" \"presets/**/*.md\"",
    "format:doc:fix": "prettier --ignore-unknown --write README.md \"docs/**/*.{md,html}\" \"presets/**/*.md\"",
    "format:preview": "prettier --ignore-unknown --check \"docs/**/*.{md,html}\"",
    "format:preview:fix": "prettier --ignore-unknown --write \"docs/**/*.{md,html}\"",
    "format:portal": "prettier --ignore-unknown --check package.json package-lock.json biome.json tsconfig.portal.json vite.portal.config.ts eslint.config.mjs .prettierrc.json .prettierignore \"internal/portal/portal_ui_src/**/*.{html,ts,vue}\" \"internal/portal/portal_ui/*.html\"",
    "format:portal:fix": "prettier --ignore-unknown --write package.json package-lock.json biome.json tsconfig.portal.json vite.portal.config.ts eslint.config.mjs .prettierrc.json .prettierignore \"internal/portal/portal_ui_src/**/*.{html,ts,vue}\" \"internal/portal/portal_ui/*.html\"",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "internal/portal/portal_ui_src/**/*.{ts,vue}": [
      "eslint --fix",
      "biome check --write",
      "prettier --ignore-unknown --write"
    ],
    "internal/portal/portal_ui_src/**/*.html": "prettier --ignore-unknown --write",
    "internal/portal/portal_ui/*.html": "prettier --ignore-unknown --write",
    "{package.json,package-lock.json,biome.json,eslint.config.mjs,tsconfig.portal.json,vite.portal.config.ts,.prettierrc.json,.prettierignore}": "prettier --ignore-unknown --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@eslint/js": "^9.26.0",
    "@quasar/vite-plugin": "^1.12.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "eslint": "^9.26.0",
    "eslint-plugin-vue": "^10.9.2",
    "html-validate": "^11.1.0",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.5.3",
    "sass-embedded": "^1.100.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "typescript-language-server": "^5.3.0",
    "vite": "^5.4.14",
    "vue-eslint-parser": "^10.4.1",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.9"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@quasar/extras": "^2.0.2",
    "codemirror": "^6.0.2",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "quasar": "^2.21.0",
    "sigma": "^3.0.3",
    "vue": "^3.5.13"
  }
}
