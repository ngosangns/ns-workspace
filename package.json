{
  "name": "ns-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build:preview": "vite build",
    "check:preview": "vue-tsc -p tsconfig.vue.json --noEmit",
    "lint:docs": "npm run lint:docs:markdown && npm run lint:docs:html",
    "lint:docs:html": "html-validate \"docs/**/*.html\" \"internal/preview/preview_ui_src/**/*.html\" \"internal/preview/preview_ui/*.html\"",
    "lint:docs:markdown": "markdownlint-cli2 \"README.md\" \"docs/**/*.md\" \"presets/**/*.md\"",
    "lint:preview": "npm run lint:preview:eslint && npm run lint:preview:biome",
    "lint:preview:biome": "biome check",
    "lint:preview:biome:fix": "biome check --write",
    "lint:preview:eslint": "eslint \"internal/preview/preview_ui_src/**/*.{ts,vue}\"",
    "lint:preview:eslint:fix": "eslint \"internal/preview/preview_ui_src/**/*.{ts,vue}\" --fix",
    "lint:preview:fix": "npm run lint:preview:eslint:fix && npm run lint:preview:biome:fix && npm run format:preview",
    "format:docs": "prettier --ignore-unknown --write README.md \"docs/**/*.{md,html}\" \"presets/**/*.md\" \"internal/preview/preview_ui_src/**/*.html\" \"internal/preview/preview_ui/*.html\"",
    "format:docs:check": "prettier --ignore-unknown --check README.md \"docs/**/*.{md,html}\" \"presets/**/*.md\" \"internal/preview/preview_ui_src/**/*.html\" \"internal/preview/preview_ui/*.html\"",
    "format:preview": "prettier --ignore-unknown --write package.json package-lock.json biome.json tsconfig.preview.json eslint.config.mjs .prettierrc.json .prettierignore README.md \"docs/**/*.md\" \"internal/preview/preview_ui_src/**/*.{html,ts,vue}\" \"internal/preview/preview_ui/*.html\"",
    "format:preview:check": "prettier --ignore-unknown --check package.json package-lock.json biome.json tsconfig.preview.json eslint.config.mjs .prettierrc.json .prettierignore README.md \"docs/**/*.md\" \"internal/preview/preview_ui_src/**/*.{html,ts,vue}\" \"internal/preview/preview_ui/*.html\"",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "internal/preview/preview_ui_src/**/*.ts": [
      "eslint --fix",
      "biome check --write",
      "prettier --ignore-unknown --write"
    ],
    "internal/preview/preview_ui_src/**/*.vue": [
      "eslint --fix",
      "biome check --write",
      "prettier --ignore-unknown --write"
    ],
    "internal/preview/preview_ui_src/**/*.html": "prettier --ignore-unknown --write",
    "internal/preview/preview_ui/*.html": "prettier --ignore-unknown --write",
    "{package.json,package-lock.json,biome.json,eslint.config.mjs,tsconfig.preview.json,tsconfig.vue.json,vite.config.ts,.prettierrc.json,.prettierignore}": "prettier --ignore-unknown --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@eslint/js": "^9.26.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "eslint": "^9.26.0",
    "eslint-plugin-vue": "^10.9.2",
    "html-validate": "^11.1.0",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.5.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "typescript-language-server": "^5.3.0",
    "vite": "^5.4.14",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.9"
  },
  "dependencies": {
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "sigma": "^3.0.3",
    "vue": "^3.5.13"
  }
}
