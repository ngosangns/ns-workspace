<!DOCTYPE html>
<!--
  ns-workspace static knowledge-base export.

  Self-contained when generated with --inline-assets=true (default): the vendor
  libraries (Cytoscape.js, marked) and the knowledge bundle are embedded inline,
  so this file renders fully over file:// with no network requests.

  Template fields (populated by exportStaticBundle / injectBundle):
    .Title       page title (project name)
    .StyleCSS    contents of export.css (template.CSS)
    .VendorHead  vendor <script> tags, inline or CDN (template.HTML)
    .BundleJSON  the knowledge bundle assigned to window.__NS_KB__ (template.JS)
    .AppJS       contents of export.js (template.JS)
-->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content="ns-workspace export" />
    <title>{{.Title}}</title>
    <style>{{.StyleCSS}}</style>
  </head>
  <body>
    <div id="kb-app">
      <aside id="kb-sidebar">
        <div class="kb-brand">
          <h1 id="kb-brand-title">Knowledge Base</h1>
          <div class="kb-sub" id="kb-brand-sub"></div>
        </div>
        <div class="kb-search">
          <input
            id="kb-search-input"
            type="search"
            placeholder="Filter documents…"
            autocomplete="off"
            spellcheck="false"
          />
        </div>
        <ul id="kb-doc-list"></ul>
        <nav class="kb-nav" id="kb-nav">
          <button type="button" data-view="doc" class="active">Docs</button>
          <button type="button" data-view="graph">Graph</button>
        </nav>
      </aside>

      <section id="kb-content">
        <article id="kb-doc"></article>
        <div id="kb-graph"><div id="kb-cy"></div></div>
      </section>
    </div>

    <!-- Vendor libraries: inline (offline) or CDN reference. -->
    {{.VendorHead}}

    <!-- Knowledge bundle injected as a JSON blob. -->
    <script>
      window.__NS_KB__ = {{.BundleJSON}};
    </script>

    <!-- Export UI (vanilla, no build step). -->
    <script>{{.AppJS}}</script>
  </body>
</html>
