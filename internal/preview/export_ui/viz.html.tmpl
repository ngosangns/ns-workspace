<!DOCTYPE html>
<!--
  ns-workspace static knowledge-base export.

  The viewer is the Open Knowledge Format (OKF) bundle viewer (SolidJS port of
  GoogleCloudPlatform/knowledge-catalog, Apache 2.0; see COPYRIGHT.md). It is
  self-contained when generated with --inline-assets=true (default): the vendor
  libraries (Cytoscape.js, marked) and the knowledge bundle are embedded inline,
  so this file renders fully over file:// with no network requests.

  Template fields (populated by exportStaticBundle / injectBundle):
    .Title       page title (project name)
    .StyleCSS    contents of viz.css (template.CSS)
    .VendorHead  vendor <script> tags, inline or CDN (template.HTML)
    .BundleName  display name shown in the viewer header (template.JS, JSON string)
    .BundleJSON  the OKF bundle assigned to window.BUNDLE (template.JS)
    .AppJS       contents of viz.js (template.JS)
-->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content="ns-workspace export" />
    <title>{{.Title}}</title>
    <style>{{.StyleCSS}}</style>
  </head>
  <body>
    <div id="export-root"></div>

    <!-- Vendor libraries: inline (offline) or CDN reference. -->
    {{.VendorHead}}

    <!-- Knowledge bundle injected as a JSON blob (OKF shape). -->
    <script>
      window.BUNDLE_NAME = {{.BundleName}};
      window.BUNDLE = {{.BundleJSON}};
    </script>

    <!-- Export UI (OKF viewer, SolidJS build). -->
    <script>{{.AppJS}}</script>
  </body>
</html>
