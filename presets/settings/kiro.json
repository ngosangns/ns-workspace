{
  "name": "ns-full",
  "description": "ns-workspace managed agent: full permissions / yolo (every tool available and pre-approved). Loads synced skills and steering from ~/.kiro. Default model: gpt-5.6-terra.",
  "prompt": null,
  "mcpServers": {},
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "@builtin",
    "@*"
  ],
  "resources": [
    "skill://~/.kiro/skills/*/SKILL.md",
    "file://~/.kiro/steering/**/*.md"
  ],
  "hooks": {},
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        ".*"
      ],
      "autoAllowReadonly": true
    },
    "write": {
      "allowedPaths": [
        "**",
        "~/**",
        "/**"
      ]
    },
    "read": {
      "allowedPaths": [
        "**",
        "~/**",
        "/**"
      ]
    },
    "glob": {
      "allowReadOnly": true,
      "allowedPaths": [
        "**",
        "~/**",
        "/**"
      ]
    },
    "grep": {
      "allowReadOnly": true,
      "allowedPaths": [
        "**",
        "~/**",
        "/**"
      ]
    },
    "web_fetch": {
      "trusted": [
        ".*"
      ]
    },
    "aws": {
      "autoAllowReadonly": true
    },
    "subagent": {
      "trustedAgents": [
        "*"
      ]
    }
  },
  "includeMcpJson": true,
  "model": "gpt-5.6-terra"
}
