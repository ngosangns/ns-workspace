{
  "id": "qoder",
  "target": ".qoder/settings.json",
  "defaultPreset": "presets/settings/default.json",
  "preset": "presets/settings/qoder.json",
  "merge": {
    "hooks": {
      "strategy": "merge-deep",
      "from": "default"
    },
    "general": {
      "strategy": "replace",
      "from": "preset"
    },
    "mcpServers": {
      "strategy": "merge-shallow",
      "from": "shared"
    }
  }
}
