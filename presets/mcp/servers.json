{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "local-figma": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "safari": {
      "command": "npx",
      "args": ["-y", "safari-mcp"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "kimi": {
      "command": "npx",
      "args": ["-y", "kimi-for-claude"]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "-p",
        "3.13",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context=antigravity",
        "--project-from-cwd"
      ]
    },
    "code-review-graph": {
      "command": "uvx",
      "args": ["code-review-graph", "serve"]
    },
    "headroom": {
      "command": "uvx",
      "args": ["--from", "headroom-ai[mcp]", "headroom", "mcp", "serve"]
    }
  }
}
